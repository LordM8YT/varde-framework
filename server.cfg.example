# Minimal development configuration for FiveM for GTAV Enhanced / Cfx Server.
# Copy this file outside the repository and add your own sv_licenseKey.

endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

sv_hostname "Varde Framework Development"
sets sv_projectName "Varde Framework"
sets sv_projectDesc "Varde — an independent Enhanced-first framework"
sv_maxclients 8

# OneSync is always enabled by Cfx Server for Enhanced and its convar is
# read-only. txAdmin recipes should use `$onesync: on` instead.
set sv_stateBagStrictMode true

# Enables Enhanced client developer tools. Disable this in production, or
# replace it with per-player deferrals.handover access.
set sv_devMode true

# Core settings can override config/defaults.json without editing the resource.
set varde_maxCharacters 4
set varde_saveIntervalMs 60000

ensure varde_core
ensure varde_jobs
ensure varde_inventory
ensure varde_admin
ensure varde_phone
ensure varde_identity
ensure varde_example

# Job-management commands are denied to players unless their principal inherits
# this ACE. Example:
# add_ace group.admin varde.jobs.manage allow
# add_ace group.admin varde.admin allow

# Add this locally. Never commit a real key.
# sv_licenseKey "..."
